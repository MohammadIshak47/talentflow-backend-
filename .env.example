# PostgreSQL connection string.
# Local example:    postgresql://postgres:postgres@localhost:5432/talentflow
# Neon/Supabase example (free hosted Postgres, works well with Render/Railway/Fly):
#   postgresql://user:password@ep-xxxx.neon.tech/talentflow?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/talentflow

# Random long string used to sign JWTs. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-this-to-a-long-random-string

ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Comma-separated list of allowed frontend origins (no trailing slash)
# Add your Netlify/Vercel URLs here once deployed.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
